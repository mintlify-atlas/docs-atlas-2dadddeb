    "GET /api/doubt/:shareId - Get shared doubt solution",
    "POST /api/citations/generate - Generate citation",
    "POST /api/cornell-notes/generate - Generate Cornell notes",
    "POST /api/flashcards/generate - Generate flashcards",
    "POST /api/study-guide/generate - Generate study guide",
    "POST /api/summarizer/generate - Generate text summary",
    "POST /api/streaks/activity - Log study activity",
    "GET /api/streaks/current - Get current streak",
    "POST /api/forum/posts - Create forum post",
    "GET /api/forum/posts - List forum posts"
